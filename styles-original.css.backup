@import "tailwindcss";

@theme {
  /* Custom color palette extracted from original design */
  --color-primary: #10b981;
  --color-primary-dark: #059669;
  --color-secondary: #3b82f6;
  --color-secondary-dark: #2563eb;
  --color-danger: #ef4444;
  --color-warning: #f59e0b;
  
  /* Background gradients */
  --gradient-main: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --gradient-dark: linear-gradient(135deg, #1e293b 0%, #334155 100%);
  --gradient-button-primary: linear-gradient(135deg, #10b981 0%, #059669 100%);
  --gradient-button-secondary: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  
  /* Custom spacing for 8px grid system */
  --spacing-18: 4.5rem;
  --spacing-22: 5.5rem;
  
  /* Custom border radius */
  --radius-3xl: 1.5rem;
  --radius-4xl: 2rem;
  
  /* Custom shadows */
  --shadow-custom: 0 20px 40px rgb(0 0 0 / 0.1);
  --shadow-hover: 0 6px 16px rgb(16 185 129 / 0.3);
  --shadow-active: 0 4px 12px rgb(16 185 129 / 0.2);
  
  /* Typography */
  --font-family-display: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
  --font-family-mono: 'JetBrains Mono', 'Fira Code', monospace;
}

/* Base styles */
@layer base {
  :root {
    font-family: var(--font-family-display);
    font-size: 16px;
    line-height: 1.5;
    font-weight: 400;
    color: #1f2937;
    background: var(--gradient-main);
    min-height: 100vh;
    font-synthesis: none;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    -webkit-text-size-adjust: 100%;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: inherit;
  }
  
  @media (prefers-color-scheme: dark) {
    :root {
      color: #f9fafb;
      background: var(--gradient-dark);
    }
  }
}

/* Custom utilities for complex animations and effects */
@layer utilities {
  .progress-ring {
    transform: rotate(-90deg);
    filter: drop-shadow(0 4px 8px rgb(0 0 0 / 0.1));
  }

  .progress-ring-circle {
    transition: stroke-dashoffset 0.5s ease-in-out;
    stroke-linecap: round;
  }
  
  .bg-glass {
    background: rgb(255 255 255 / 0.95);
    backdrop-filter: blur(20px);
  }
  
  .bg-glass-dark {
    background: rgb(15 23 42 / 0.95);
  }
  
  .gradient-text {
    background: var(--gradient-button-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
}