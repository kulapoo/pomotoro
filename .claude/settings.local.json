{
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cat:*)",
      "Bash(rm:*)",
      "Bash(find:*)",
      "Bash(cargo test:*)",
      "WebSearch",
      "WebFetch(domain:burntsushi.net)",
      "Bash(mkdir:*)",
      "Bash(tree:*)",
      "Bash(just test:*)",
      "Bash(git log:*)",
      "Bash(cargo run:*)",
      "Bash(cargo clippy:*)",
      "Bash(RUST_LOG=debug cargo test timer::test_start_timer)",
      "Bash(export RUST_LOG=debug)",
      "Bash(rustc:*)",
      "Bash(./test_timer_save)",
      "Bash(cargo fix:*)",
      "Bash(diesel migration generate:*)",
      "Bash(git restore:*)",
      "Bash(timeout 30 cargo test --test main timer)",
      "Bash(RUST_BACKTRACE=1 cargo test --package infra config_changes_should_apply_to_new_timer_sessions -- --nocapture)",
      "Bash(RUST_LOG=debug cargo test --package infra config_changes_should_apply_to_new_timer_sessions -- --nocapture)",
      "Bash(RUST_BACKTRACE=1 cargo test --package infra --test main should_handle_invalid_sessions_until_long_break -- --nocapture)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "plan"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read file_path; if echo \\\"$file_path\\\" | grep -q '\\\\.rs$'; then rustfmt \\\"$file_path\\\"; fi; }"
          }
        ]
      }
    ]
  }
}