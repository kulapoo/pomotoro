{
  "permissions": {
    "allow": [
      "Bash(cargo clean:*)",
      "Bash(cargo test:*)",
      "Bash(for i in {1..5})",
      "Bash(do echo \"=== Run $i ===\")",
      "Bash(done)",
      "Bash(tee:*)",
      "Read(//tmp/**)",
      "Bash(for i in {1..3})",
      "Bash(grep:*)",
      "Bash(xargs ls:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "plan"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read file_path; if echo \\\"$file_path\\\" | grep -q '\\\\.rs$'; then rustfmt \\\"$file_path\\\"; fi; }"
          }
        ]
      }
    ]
  }
}