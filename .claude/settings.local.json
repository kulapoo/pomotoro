{
  "permissions": {
    "allow": [
      "Bash(cargo clean:*)",
      "Bash(cargo test:*)",
      "Bash(for i in {1..5})",
      "Bash(do echo \"=== Run $i ===\")",
      "Bash(done)",
      "Bash(tee:*)",
      "Read(//tmp/**)",
      "Bash(for i in {1..3})",
      "Bash(grep:*)",
      "Bash(xargs ls:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(trunk build:*)",
      "Bash(just dev:*)",
      "Bash(echo $DISPLAY)",
      "Bash(curl -I http://localhost:1420)",
      "Bash(RUST_LOG=debug timeout 3 /home/jpt/src/oss/pomotoro/target/debug/infra)",
      "Bash(wmctrl:*)",
      "Bash(xwininfo:*)",
      "Bash(find:*)",
      "Read(//home/jpt/.local/share/pomotoro/**)",
      "Bash(sqlite3:*)",
      "Bash(./target/release/infra)",
      "Bash(RUST_BACKTRACE=1 ./target/release/infra)",
      "Bash(pkill:*)",
      "Bash(echo $HOME)",
      "Bash(python3:*)",
      "Bash(RUST_BACKTRACE=1 timeout 3 ./target/release/infra)",
      "Bash(cargo run:*)",
      "Bash(RUST_BACKTRACE=1 cargo run --bin infra)",
      "Bash(RUST_LOG=debug cargo run --bin infra)",
      "Bash(env RUST_LOG=debug cargo run --bin infra)",
      "Bash(timeout 3 cargo run --bin infra)",
      "Bash(cargo tauri dev:*)",
      "Bash(chmod:*)",
      "Bash(/home/jpt/src/oss/pomotoro/test_pause.sh:*)",
      "Bash(cargo tree:*)",
      "WebSearch",
      "WebFetch(domain:v2.tauri.app)",
      "Bash(RUST_LOG=debug timeout 5 cargo run --bin infra)",
      "Bash(RUST_BACKTRACE=1 timeout 5 cargo run --bin infra)",
      "Bash(RUST_BACKTRACE=full cargo run --bin infra)",
      "Bash(env RUST_BACKTRACE=full cargo run --bin infra)",
      "Bash(timeout 2 cargo run --bin infra)",
      "Bash(timeout 5 cargo run --bin infra)",
      "Bash(cargo fix:*)",
      "Bash(rustc:*)",
      "Bash(./test_timer_ser)",
      "Bash(mkdir:*)",
      "Bash(/tmp/test_skip_events:*)",
      "Bash(rm:*)",
      "Bash(tree:*)",
      "Bash(for dir in /home/jpt/src/oss/pomotoro/infra/src/commands/*/)",
      "Bash(git mv:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read file_path; if echo \\\"$file_path\\\" | grep -q '\\\\.rs$'; then rustfmt \\\"$file_path\\\"; fi; }"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); user=$(whoami); host=$(hostname -s); dir=$(basename \"$cwd\"); branch=$(cd \"$cwd\" 2>/dev/null && git -c core.fileMode=false rev-parse --abbrev-ref HEAD 2>/dev/null || echo ''); git_info=''; if [ -n \"$branch\" ]; then git_info=$(cd \"$cwd\" 2>/dev/null && printf \" on 🌵 \"; git -c core.fileMode=false diff --quiet 2>/dev/null && printf \"\\033[1;32m✓\\033[0m\" || printf \"\\033[0;31m✗\\033[0m\"; printf \" $branch\"); fi; printf \"🤘-🐧 \\033[1;32m%s\\033[0m @ 💻 \\033[1;36m%s\\033[0m - 🧱 \\033[1;35m%s\\033[0m%s\" \"$user\" \"$host\" \"$dir\" \"$git_info\""
  }
}
