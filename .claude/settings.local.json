{
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cat:*)",
      "Bash(rm:*)",
      "Bash(find:*)",
      "Bash(cargo test:*)",
      "WebSearch",
      "WebFetch(domain:burntsushi.net)",
      "Bash(mkdir:*)",
      "Bash(tree:*)",
      "Bash(just test:*)",
      "Bash(git log:*)",
      "Bash(cargo run:*)",
      "Bash(cargo clippy:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read file_path; if echo \\\"$file_path\\\" | grep -q '\\\\.rs$'; then rustfmt \\\"$file_path\\\"; fi; }"
          }
        ]
      }
    ]
  }
}