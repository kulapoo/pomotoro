{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pomotoro",
  "version": "0.1.0",
  "identifier": "com.jpt.pomotoro",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "frontendDist": "../react-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "pomotoro",
        "width": 1500,
        "height": 1200,
        "additionalBrowserArgs": "--auto-open-devtools-for-tabs --disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
