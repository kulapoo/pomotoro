{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pomotoro",
  "version": "0.1.0",
  "identifier": "com.jpt.pomotoro",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "frontendDist": "../react-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Pomotoro",
        "width": 490,
        "height": 844,
        "resizable": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "app",
      "dmg",
      "msi",
      "nsis"
    ],
    "shortDescription": "A Pomodoro timer for focused work sessions with task tracking and system tray integration",
    "longDescription": "Pomotoro helps you stay productive with customizable Pomodoro work/break intervals, task tracking, notifications, audio cues, and a system tray controller \u2014 all in a clean cross-platform desktop app.",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libssl3",
          "libayatana-appindicator3-1"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
